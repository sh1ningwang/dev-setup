#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
OS="$(uname -s)"

# ── Package definitions ─────────────────────────────────────────────
# Each package declares:
#   pkg_source  – path(s) relative to $REPO_DIR/<pkg>/
#   pkg_target  – absolute target path(s)
#   pkg_mode    – "file" | "dir" | "glob"
#
# "file"  → symlink a single file
# "dir"   → symlink entire directory
# "glob"  → symlink each matching file individually

declare -a PACKAGES=(claude-code flameshot git ghostty lazygit neovim rime)

pkg_source_claude_code="settings.json"
pkg_mode_claude_code="file"
pkg_target_claude_code="$HOME/.claude/settings.json"

pkg_mode_git="custom"

pkg_source_flameshot="flameshot.ini"
pkg_mode_flameshot="file"
pkg_target_flameshot="$HOME/.config/flameshot/flameshot.ini"

pkg_source_ghostty="config"
pkg_mode_ghostty="file"
if [[ "$OS" == "Darwin" ]]; then
    pkg_target_ghostty="$HOME/Library/Application Support/com.mitchellh.ghostty/config"
else
    pkg_target_ghostty="$HOME/.config/ghostty/config"
fi

pkg_source_lazygit="config.yml"
pkg_mode_lazygit="file"
if [[ "$OS" == "Darwin" ]]; then
    pkg_target_lazygit="$HOME/Library/Application Support/lazygit/config.yml"
else
    pkg_target_lazygit="$HOME/.config/lazygit/config.yml"
fi

pkg_source_neovim="."
pkg_mode_neovim="dir"
pkg_target_neovim="$HOME/.config/nvim"

pkg_source_rime="*.yaml"
pkg_mode_rime="glob"
if [[ "$OS" == "Darwin" ]]; then
    pkg_target_dir_rime="$HOME/Library/Rime"
else
    pkg_target_dir_rime="$HOME/.local/share/fcitx5/rime"
fi

# ── Helpers ──────────────────────────────────────────────────────────

# Sanitise package name for variable indirection (- → _)
sanitize() { echo "${1//-/_}"; }

get_field() {
    local var="pkg_${1}_$(sanitize "$2")"
    echo "${!var}"
}

# Return the repo subdirectory for a package (defaults to pkg name)
get_basedir() {
    local pkg="$1"
    local var="pkg_basedir_$(sanitize "$pkg")"
    local val="${!var:-}"
    echo "${val:-$pkg}"
}

BACKUP_ROOT="$HOME/.dev-setup-backup"
BACKUP_DIR=""           # set lazily on first actual backup
BACKUP_TIMESTAMP=""

ensure_backup_dir() {
    if [[ -z "$BACKUP_DIR" ]]; then
        BACKUP_TIMESTAMP="$(date '+%Y%m%d-%H%M%S')"
        BACKUP_DIR="$BACKUP_ROOT/backup-$BACKUP_TIMESTAMP"
    fi
}

# Back up a single path into $BACKUP_DIR/<pkg>/
backup_path() {
    local pkg="$1" path="$2"
    ensure_backup_dir
    local dest="$BACKUP_DIR/$pkg"
    mkdir -p "$dest"
    mv "$path" "$dest/"
}

# Create symlink, printing status
make_link() {
    local src="$1" target="$2"
    mkdir -p "$(dirname "$target")"
    ln -s "$src" "$target"
}

# Check if a symlink already points to the expected source
is_correct_link() {
    local target="$1" expected_src="$2"
    [[ -L "$target" ]] && [[ "$(readlink "$target")" == "$expected_src" ]]
}

# ── Linking logic per mode ───────────────────────────────────────────

link_file() {
    local pkg="$1"
    local src="$REPO_DIR/$(get_basedir "$pkg")/$(get_field source "$pkg")"
    local target
    target="$(get_field target "$pkg")"

    if is_correct_link "$target" "$src"; then
        echo "  ✓ $target → already linked"
        return
    fi
    if [[ -e "$target" || -L "$target" ]]; then
        backup_path "$pkg" "$target"
        echo "  ↪ backed up $target"
    fi
    make_link "$src" "$target"
    echo "  ✓ $target → $src"
}

link_dir() {
    local pkg="$1"
    local src="$REPO_DIR/$(get_basedir "$pkg")/$(get_field source "$pkg")"
    local target
    target="$(get_field target "$pkg")"

    if is_correct_link "$target" "$src"; then
        echo "  ✓ $target → already linked"
        return
    fi
    if [[ -e "$target" || -L "$target" ]]; then
        backup_path "$pkg" "$target"
        echo "  ↪ backed up $target"
    fi
    make_link "$src" "$target"
    echo "  ✓ $target → $src"
}

link_glob() {
    local pkg="$1"
    local pattern="$REPO_DIR/$(get_basedir "$pkg")/$(get_field source "$pkg")"
    local target_dir
    target_dir="$(get_field target_dir "$pkg")"

    local files
    files=($pattern)  # glob expansion
    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (no files matched $pattern)"
        return
    fi

    for src in "${files[@]}"; do
        local basename
        basename="$(basename "$src")"
        local target="$target_dir/$basename"

        if is_correct_link "$target" "$src"; then
            echo "  ✓ $target → already linked"
            continue
        fi
        if [[ -e "$target" || -L "$target" ]]; then
            backup_path "$pkg" "$target"
            echo "  ↪ backed up $target"
        fi
        make_link "$src" "$target"
        echo "  ✓ $target → $src"
    done
}

link_custom_git() {
    local pkg="git"

    # Main config
    local src="$REPO_DIR/git/config"
    local target="$HOME/.gitconfig"
    if is_correct_link "$target" "$src"; then
        echo "  ✓ $target → already linked"
    else
        if [[ -e "$target" || -L "$target" ]]; then
            backup_path "$pkg" "$target"
            echo "  ↪ backed up $target"
        fi
        make_link "$src" "$target"
        echo "  ✓ $target → $src"
    fi

    # Profile configs
    for src in "$REPO_DIR"/git/*.gitconfig; do
        [[ -e "$src" ]] || continue
        local basename
        basename="$(basename "$src")"
        local target="$HOME/.config/git/$basename"
        if is_correct_link "$target" "$src"; then
            echo "  ✓ $target → already linked"
            continue
        fi
        if [[ -e "$target" || -L "$target" ]]; then
            backup_path "$pkg" "$target"
            echo "  ↪ backed up $target"
        fi
        make_link "$src" "$target"
        echo "  ✓ $target → $src"
    done
}

link_package() {
    local pkg="$1"
    local mode
    mode="$(get_field mode "$pkg")"
    echo "[$pkg]"
    case "$mode" in
        file)   link_file "$pkg" ;;
        dir)    link_dir  "$pkg" ;;
        glob)   link_glob "$pkg" ;;
        custom) "link_custom_$(sanitize "$pkg")" ;;
    esac
}

# ── Interactive selector ─────────────────────────────────────────────

show_menu() {
    echo "Available packages:"
    echo ""
    for i in "${!PACKAGES[@]}"; do
        local pkg="${PACKAGES[$i]}"
        if [[ "${selected[$i]}" -eq 1 ]]; then
            echo "  $((i+1))) [x] $pkg"
        else
            echo "  $((i+1))) [ ] $pkg"
        fi
    done
    echo ""
    echo "Toggle: number | a=all | n=none | Enter=confirm | q=quit"
}

interactive_select() {
    local count=${#PACKAGES[@]}
    local -a selected
    for ((i=0; i<count; i++)); do selected[$i]=0; done

    while true; do
        # Clear screen and redraw
        printf '\033[2J\033[H'
        show_menu
        printf "> "
        read -r input

        case "$input" in
            q|Q)
                echo "Aborted."
                exit 0
                ;;
            a|A)
                for ((i=0; i<count; i++)); do selected[$i]=1; done
                ;;
            n|N)
                for ((i=0; i<count; i++)); do selected[$i]=0; done
                ;;
            "")
                # Confirm selection
                local any=0
                for ((i=0; i<count; i++)); do
                    if [[ "${selected[$i]}" -eq 1 ]]; then any=1; break; fi
                done
                if [[ "$any" -eq 0 ]]; then
                    echo "Nothing selected."
                    exit 0
                fi
                SELECTED=("${selected[@]}")
                return
                ;;
            *)
                # Try to parse as number(s) — support "1 3 5" or "1,3,5" or just "2"
                local nums
                nums="${input//,/ }"
                for n in $nums; do
                    if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= count )); then
                        local idx=$((n-1))
                        selected[$idx]=$(( 1 - selected[$idx] ))
                    fi
                done
                ;;
        esac
    done
}

# ── Check mode ───────────────────────────────────────────────────────

check_file() {
    local pkg="$1"
    local src="$REPO_DIR/$(get_basedir "$pkg")/$(get_field source "$pkg")"
    local target
    target="$(get_field target "$pkg")"

    if is_correct_link "$target" "$src"; then
        echo "  [x] $target"
    else
        echo "  [ ] $target"
    fi
}

check_dir() {
    check_file "$1"
}

check_glob() {
    local pkg="$1"
    local pattern="$REPO_DIR/$(get_basedir "$pkg")/$(get_field source "$pkg")"
    local target_dir
    target_dir="$(get_field target_dir "$pkg")"

    local files
    files=($pattern)
    if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (no config files found)"
        return
    fi

    for src in "${files[@]}"; do
        local basename
        basename="$(basename "$src")"
        local target="$target_dir/$basename"

        if is_correct_link "$target" "$src"; then
            echo "  [x] $target"
        else
            echo "  [ ] $target"
        fi
    done
}

check_custom_git() {
    local src="$REPO_DIR/git/config"
    local target="$HOME/.gitconfig"
    if is_correct_link "$target" "$src"; then
        echo "  [x] $target"
    else
        echo "  [ ] $target"
    fi

    for src in "$REPO_DIR"/git/*.gitconfig; do
        [[ -e "$src" ]] || continue
        local basename
        basename="$(basename "$src")"
        local target="$HOME/.config/git/$basename"
        if is_correct_link "$target" "$src"; then
            echo "  [x] $target"
        else
            echo "  [ ] $target"
        fi
    done
}

check_package() {
    local pkg="$1"
    local mode
    mode="$(get_field mode "$pkg")"
    echo "$pkg"
    case "$mode" in
        file)   check_file "$pkg" ;;
        dir)    check_dir  "$pkg" ;;
        glob)   check_glob "$pkg" ;;
        custom) "check_custom_$(sanitize "$pkg")" ;;
    esac
}

run_check() {
    echo "dev-setup linker — OS: $OS"
    echo ""
    for pkg in "${PACKAGES[@]}"; do
        check_package "$pkg"
    done
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
    echo "dev-setup linker — OS: $OS"
    echo ""

    declare -a SELECTED
    interactive_select

    printf '\033[2J\033[H'
    echo "dev-setup linker — OS: $OS"
    echo ""

    for i in "${!PACKAGES[@]}"; do
        if [[ "${SELECTED[$i]}" -eq 1 ]]; then
            link_package "${PACKAGES[$i]}"
            echo ""
        fi
    done

    if [[ -n "$BACKUP_DIR" && -d "$BACKUP_DIR" ]]; then
        echo "Backups saved to: $BACKUP_DIR"
    fi

    echo "Done."
}

if [[ "${1:-}" == "--check" ]]; then
    run_check
else
    main
fi
